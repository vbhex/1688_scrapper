# 1688.com Credentials
ALIBABA_1688_USERNAME=your_1688_username
ALIBABA_1688_PASSWORD=your_1688_password

# Translation API — auto-detects provider:
#   Baidu (for China MacBook): register at https://fanyi-api.baidu.com/
#   Google (for main computer): requires GOOGLE_CLOUD_API_KEY
BAIDU_TRANSLATE_APPID=
BAIDU_TRANSLATE_SECRET=
GOOGLE_CLOUD_API_KEY=

# Product Filter Settings
MIN_PRICE_CNY=37
MAX_PRICE_CNY=500
MIN_ORDER_QTY=1
PRICE_MARKUP=2

# Categories (comma-separated)
CATEGORIES=earphones,smart watches,speakers,action cameras,wireless charger,gaming mouse,mechanical keyboard,power bank,ip camera,portable projector,translator,lavalier microphone,usb hub,webcam,solar panel,smart ring,gps tracker,soundbar,vr glasses,gimbal stabilizer,power station,smart doorbell,phone cooler,sim router

# Proxy (optional - leave empty to disable)
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# Run Mode
TEST_MODE=false
TEST_PRODUCT_LIMIT=5

# MySQL Database Configuration
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=1688_source
